# IP del ESP32-CAM en la red WiFi (ver Serial monitor al arrancar el firmware)
ESP32_IP=192.168.1.50

# Puertos del firmware AlertDrive_ESP32CAM.ino (no cambiar salvo que se cambien en el .ino)
ESP32_STREAM_PORT=81
ESP32_CONTROL_PORT=82

# Cada cuanto se consulta /status del ESP32 (ms)
POLL_INTERVAL_MS=1500

# Puerto donde corre este backend / dashboard
PORT=3000
